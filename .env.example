# roam-panel hub configuration — source this before `roam-panel serve`.
# (never commit the real .env — it holds secrets.)

# Worker bearer token: roam agents send it as `--hub-token`. Mint one with:
#   roam-panel token --gen
ROAM_HUB_TOKEN=

# HMAC key that signs the one-tap approve/deny links in emails. Random, keep secret.
# Rotating it invalidates outstanding email links.
ROAM_PANEL_SECRET=

# Public URL of this hub (used to build the one-tap links).
PANEL_URL=https://panel.roam.intrane.fr

# Resend, for the "agent parked" email. Leave RESEND_API_KEY empty to disable email
# (the web panel still works). APPROVE_EMAIL is where notifications are sent.
RESEND_API_KEY=
RESEND_FROM=Roam Panel <javi@intrane.fr>
APPROVE_EMAIL=

# Password for the web panel (browse UI + approve/deny buttons). The worker endpoints
# and one-tap email links have their own auth, so this only guards the human UI.
PANEL_PASSWORD=

# Telegram approval notifications (optional). Create a bot via @BotFather, set its token
# + username here. Users connect from the panel (a t.me/<bot>?start=<code> deep link); a
# background poller links their chat. Park requests then arrive in Telegram with inline
# Approve/Deny buttons, alongside email.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_NAME=

# Backward-compat single-user default account: ROAM_HUB_TOKEN (above) becomes the "default"
# account's worker token, APPROVE_EMAIL its email, TELEGRAM_CHAT_ID its Telegram, and
# PANEL_PASSWORD logs into it. New users self-serve via email magic-link (each gets their
# own account + token). Leave ROAM_HUB_TOKEN empty for a pure multi-tenant hub.
TELEGRAM_CHAT_ID=

# SQLite file (created on first run).
ROAM_PANEL_DB=roam-panel.db
