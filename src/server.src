// roam-panel — the approval control-plane hub for roam.
//
// One machin binary: an agent-first CLI + a `serve` daemon (machweb + SQLite). Remote
// roam workers POST their journal + status here (`--hub`); when a worker PARKS on a
// destructive command (status `awaiting`, the exact command in `pending`) the hub emails
// you a Resend message with one-tap SIGNED approve/deny links, and you can also
// approve/deny/steer/stop from a mobile web page. Workers poll `GET /v1/decision` and
// apply your decision at their next checkpoint.
//
// Concurrency: machweb runs one goroutine per connection, so each handler opens its OWN
// SQLite connection (WAL + busy_timeout) and closes it before returning — never a shared
// handle (grepapi/crmd pattern).
//
// SAFETY: email security scanners follow GET links, so a signed link lands on a POST
// *confirmation* page (scanners don't submit forms) — the state change happens on POST.

// ---------- env / config ----------
func env_or(k, d) (v) { v = env(k)  if v == "" { v = d } }
func hub_token() (t) { t = env_or("ROAM_HUB_TOKEN", "") }
func sign_secret() (s) { s = env_or("ROAM_PANEL_SECRET", "") }
func panel_url() (u) { u = env_or("PANEL_URL", "http://localhost:8099") }
func resend_key() (k) { k = env_or("RESEND_API_KEY", "") }
func resend_from() (f) { f = env_or("RESEND_FROM", "Roam Panel <javi@intrane.fr>") }
func approve_email() (e) { e = env_or("APPROVE_EMAIL", "") }
func link_ttl() (n) { n = 1800 }   // one-tap links valid 30 min

// ---------- db ----------
func dbpath() (p) { p = env_or("ROAM_PANEL_DB", "roam-panel.db") }
func dbopen() (db) {
    db = sqlite_open(dbpath())
    sqlite_exec(db, "PRAGMA journal_mode=WAL", []string{})
    sqlite_exec(db, "PRAGMA busy_timeout=4000", []string{})
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS agents (id TEXT PRIMARY KEY, host TEXT, goal TEXT, provider TEXT, status TEXT, pending TEXT, iters INTEGER, tokens INTEGER, last_seen INTEGER, created INTEGER)", []string{})
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS events (id INTEGER PRIMARY KEY AUTOINCREMENT, agent_id TEXT, wid INTEGER, ts INTEGER, kind TEXT, msg TEXT, UNIQUE(agent_id, wid))", []string{})
    sqlite_exec(db, "CREATE TABLE IF NOT EXISTS decisions (id INTEGER PRIMARY KEY AUTOINCREMENT, agent_id TEXT, decision TEXT, arg TEXT, ts INTEGER, consumed INTEGER DEFAULT 0)", []string{})
}

// ---------- json / string helpers (absence-safe: machin parse()/json_get segfault-guarded) ----------
func err_json(status, msg) (r) { r = response(status, "application/json", "{\"ok\":false,\"error\":" + json(msg) + "}") }
// form(req,name): parse an application/x-www-form-urlencoded body (mirrors machweb query()).
func form(req, name) (v) {
    v = ""
    for _, part := range split(req.body, "&") {
        eq := index(part, "=")
        if eq > 0 {
            if substr(part, 0, eq) == name { v = url_decode(substr(part, eq + 1, len(part))) }
        }
    }
}

// ---------- worker auth (single shared bearer token for M0) ----------
func worker_authed(req) (ok) {
    ok = 0
    want := hub_token()
    if want == "" { return ok }                 // no token configured -> reject everything
    h := header(req, "authorization")
    if !has_prefix(h, "Bearer ") { return ok }
    tok := trim(substr(h, 7, len(h)))
    if sha256(tok) == sha256(want) { ok = 1 }    // compare hashes, not raw
}

// ---- panel auth: a session cookie guarding the browse UI + /api/decide. The worker
// endpoints (bearer) and the one-tap /a links (HMAC) stay public with their own auth,
// so basic-auth on the whole domain (which would break both) is NOT needed.
func panel_pass() (p) { p = env_or("PANEL_PASSWORD", "") }
func panel_authed(req) (ok) {
    ok = 0
    if panel_pass() == "" { ok = 1  return ok }   // no password set -> open (dev only)
    v, o := get_session(req, sign_secret(), "rp")
    if o == 1 && v == "ok" { ok = 1 }
}
func login_page(errmsg) (h) {
    h = "<!doctype html><html lang=en><head><meta charset=utf-8><meta name=viewport content=\"width=device-width,initial-scale=1\"><title>roam panel — sign in</title>" + styles() + "</head><body>"
    h = h + "<h1>&#128760; roam panel</h1>"
    if errmsg != "" { h = h + "<div class=ag style=\"border-color:#b91c1c\"><div class=sub>" + esc(errmsg) + "</div></div>" }
    h = h + "<form method=post action=/login class=ag><div class=row><input type=password name=password placeholder=password autofocus><button class=ap>Sign in</button></div></form></body></html>"
}
func h_login(req) (res) {
    if panel_pass() != "" && form(req, "password") == panel_pass() {
        res = redirect("/")
        res = set_session(res, sign_secret(), "rp", "ok")
        return res
    }
    res = response("200 OK", "text/html; charset=utf-8", login_page("wrong password"))
}

// ---------- one-tap link signing (HMAC-SHA256 over job|decision|exp) ----------
func sign_link(jobid, decision, exp) (t) { t = hmac_sha256(sign_secret(), jobid + "|" + decision + "|" + exp) }
func verify_link(jobid, decision, exp, t) (ok) {
    ok = 0
    if sign_secret() == "" { return ok }
    if t == "" { return ok }
    if sign_link(jobid, decision, exp) != t { return ok }
    if now() >= parse_int(exp) { return ok }     // expired
    ok = 1
}
func onetap_url(jobid, decision) (u) {
    exp := str(now() + link_ttl())
    u = panel_url() + "/a?j=" + url_encode(jobid) + "&d=" + decision + "&e=" + exp + "&t=" + sign_link(jobid, decision, exp)
}

// ---------- agent / decision storage ----------
func agent_pending(db, jobid) (p) {
    rows := sqlite_query(db, "SELECT pending FROM agents WHERE id = ?", []string{jobid})
    p = unq(jget(rows, "[0].pending"))
}
func upsert_agent(db, id, host, goal, provider, status, pending, iters, toks) {
    n := str(now())
    sqlite_exec(db, "INSERT INTO agents (id,host,goal,provider,status,pending,iters,tokens,last_seen,created) VALUES (?,?,?,?,?,?,?,?,?,?) ON CONFLICT(id) DO UPDATE SET host=excluded.host, goal=excluded.goal, provider=excluded.provider, status=excluded.status, pending=excluded.pending, iters=excluded.iters, tokens=excluded.tokens, last_seen=excluded.last_seen",
        []string{id, host, goal, provider, status, pending, str(iters), str(toks), n, n})
}
func append_events(db, jobid, body) {
    i := 0
    for i < 500 {
        raw, err := json_get(body, ".events[" + str(i) + "].id")
        if err != "" { return }
        wid := parse_int(raw)
        ts := jint(body, ".events[" + str(i) + "].ts")
        kind := jstr(body, ".events[" + str(i) + "].kind")
        msg := jstr(body, ".events[" + str(i) + "].msg")
        sqlite_exec(db, "INSERT OR IGNORE INTO events (agent_id,wid,ts,kind,msg) VALUES (?,?,?,?,?)", []string{jobid, str(wid), str(ts), kind, msg})
        i = i + 1
    }
}
func insert_decision(db, jobid, decision, arg) {
    sqlite_exec(db, "INSERT INTO decisions (agent_id,decision,arg,ts,consumed) VALUES (?,?,?,?,0)", []string{jobid, decision, arg, str(now())})
}

// ---------- Resend email on park (runs off the request path via `go`) ----------
func notify_park(jobid, host, cmd) {
    key := resend_key()
    to := approve_email()
    if key == "" { return }
    if to == "" { return }
    approve := onetap_url(jobid, "approve")
    deny := onetap_url(jobid, "deny")
    subj := "roam: agent " + host + " wants to run: " + first_n(cmd, 80)
    html := "<div style=\"font-family:system-ui,sans-serif;max-width:520px\">"
    html = html + "<p>Agent <b>" + esc(host) + "</b> (<code>" + esc(jobid) + "</code>) parked on a destructive command:</p>"
    html = html + "<pre style=\"background:#111;color:#eee;padding:12px;border-radius:8px;overflow:auto\">" + esc(cmd) + "</pre>"
    html = html + "<p><a href=\"" + approve + "\" style=\"display:inline-block;background:#16a34a;color:#fff;padding:12px 22px;border-radius:8px;text-decoration:none;font-weight:600\">Approve</a>"
    html = html + "&nbsp;&nbsp;<a href=\"" + deny + "\" style=\"display:inline-block;background:#dc2626;color:#fff;padding:12px 22px;border-radius:8px;text-decoration:none;font-weight:600\">Deny</a></p>"
    html = html + "<p style=\"color:#888;font-size:13px\">Links expire in 30 min. Or open the <a href=\"" + panel_url() + "\">panel</a>.</p></div>"
    body := "{\"from\":" + json(resend_from()) + ",\"to\":[" + json(to) + "],\"subject\":" + json(subj) + ",\"html\":" + json(html) + "}"
    hdrs := []string{"Authorization: Bearer " + key, "Content-Type: application/json"}
    st, _, _ := http_request("POST", "https://api.resend.com/emails", hdrs, body)
    if st != 200 { return }
}

// ---------- worker-facing endpoints ----------
func h_report(req) (res) {
    if worker_authed(req) == 0 { return err_json("401 Unauthorized", "bad or missing bearer token") }
    body := req.body
    jobid := jstr(body, ".job")
    if jobid == "" { return err_json("400 Bad Request", "missing job") }
    db := dbopen()
    status := jstr(body, ".status")
    pending := jstr(body, ".pending")
    prev := agent_pending(db, jobid)
    upsert_agent(db, jobid, jstr(body, ".host"), jstr(body, ".goal"), jstr(body, ".provider"), status, pending, jint(body, ".iters"), jint(body, ".tokens"))
    append_events(db, jobid, body)
    sqlite_close(db)
    if status == "awaiting" && pending != "" && pending != prev { go notify_park(jobid, jstr(body, ".host"), pending) }
    res = ok_json("{\"ok\":true}")
}
func h_decision(req) (res) {
    if worker_authed(req) == 0 { return err_json("401 Unauthorized", "bad or missing bearer token") }
    jobid := query(req, "job")
    if jobid == "" { return err_json("400 Bad Request", "missing job") }
    db := dbopen()
    rows := sqlite_query(db, "SELECT id, decision, arg FROM decisions WHERE agent_id = ? AND consumed = 0 ORDER BY id LIMIT 1", []string{jobid})
    id, err := json_get(rows, "[0].id")
    if err != "" { sqlite_close(db)  return ok_json("{}") }
    decision := unq(jget(rows, "[0].decision"))
    arg := unq(jget(rows, "[0].arg"))
    sqlite_exec(db, "UPDATE decisions SET consumed = 1 WHERE id = ?", []string{unq(id)})
    sqlite_close(db)
    res = ok_json("{\"decision\":" + json(decision) + ",\"arg\":" + json(arg) + "}")
}

// ---------- human-facing: panel actions (behind basic-auth) ----------
func h_decide(req) (res) {
    if panel_authed(req) == 0 { return err_json("403 Forbidden", "sign in to the panel first") }
    jobid := form(req, "job")
    decision := form(req, "decision")
    arg := form(req, "arg")
    if jobid == "" || decision == "" { return err_json("400 Bad Request", "missing job/decision") }
    db := dbopen()
    insert_decision(db, jobid, decision, arg)
    sqlite_close(db)
    res = redirect("/")
}

// ---------- human-facing: signed one-tap link (from email) ----------
// GET /a — verify signature, then render a POST confirmation (scanner-safe).
func h_onetap_get(req) (res) {
    jobid := query(req, "j")
    decision := query(req, "d")
    exp := query(req, "e")
    t := query(req, "t")
    if verify_link(jobid, decision, exp, t) == 0 { return response("403 Forbidden", "text/html; charset=utf-8", conf_page("Invalid or expired link", "", "", "", "", "", "")) }
    db := dbopen()
    cmd := ""
    rows := sqlite_query(db, "SELECT pending, host FROM agents WHERE id = ?", []string{jobid})
    cmd = unq(jget(rows, "[0].pending"))
    host := unq(jget(rows, "[0].host"))
    sqlite_close(db)
    res = response("200 OK", "text/html; charset=utf-8", conf_page("Confirm " + decision, jobid, decision, exp, t, cmd, host))
}
// POST /a — re-verify signature, apply the decision (scanners don't POST).
func h_onetap_post(req) (res) {
    jobid := form(req, "j")
    decision := form(req, "d")
    exp := form(req, "e")
    t := form(req, "t")
    if verify_link(jobid, decision, exp, t) == 0 { return response("403 Forbidden", "text/html; charset=utf-8", conf_page("Invalid or expired link", "", "", "", "", "", "")) }
    db := dbopen()
    insert_decision(db, jobid, decision, "")
    sqlite_close(db)
    res = response("200 OK", "text/html; charset=utf-8", done_page(decision))
}

// ---------- SSR pages ----------
func styles() (s) {
    s = "<style>"
    s = s + ":root{--bg:#0b0d10;--surf:#14181d;--surf2:#1b2027;--bd:#262c34;--tx:#e7eaef;--mut:#8b93a1;--faint:#5b6472;--amber:#f59e0b;--grn:#22c55e;--red:#ef4444}"
    s = s + "*{box-sizing:border-box;min-width:0}html,body{overflow-x:clip;max-width:100%}"
    s = s + "body{font-family:system-ui,-apple-system,'Segoe UI',Roboto,sans-serif;background:var(--bg);color:var(--tx);margin:0 auto;max-width:560px;padding:16px 14px 40px;line-height:1.45;-webkit-text-size-adjust:100%}"
    s = s + "header{display:flex;align-items:center;gap:10px;margin:2px 2px 2px;min-width:0}h1{font-size:19px;font-weight:800;letter-spacing:-.01em;margin:0}"
    s = s + ".summary{display:inline-block;font-size:12px;font-weight:700;padding:4px 12px;border-radius:999px;background:var(--surf2);color:var(--mut);margin:0 0 4px}.summary.hot{background:rgba(245,158,11,.16);color:var(--amber)}"
    s = s + ".sub{color:var(--mut);font-size:13px;margin:2px 2px 12px}"
    s = s + ".ag{background:var(--surf);border:1px solid var(--bd);border-radius:14px;padding:14px;margin:11px 0}"
    s = s + ".ag.park{border-color:rgba(245,158,11,.45);border-left:3px solid var(--amber);background:linear-gradient(180deg,rgba(245,158,11,.05),transparent 55%),var(--surf)}"
    s = s + ".ah{display:flex;align-items:center;gap:8px}.host{font-weight:700;font-size:15px;overflow-wrap:anywhere}"
    s = s + ".badge{margin-left:auto;flex:none;font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.05em;padding:3px 9px;border-radius:999px;background:var(--surf2);color:var(--mut)}"
    s = s + ".b-awaiting{background:rgba(245,158,11,.18);color:var(--amber)}.b-running{background:rgba(59,130,246,.16);color:#93c5fd}.b-done{background:rgba(34,197,94,.15);color:#86efac}.b-error{background:rgba(239,68,68,.16);color:#fca5a5}.b-halted,.b-stopped{background:var(--surf2);color:var(--faint)}"
    s = s + ".meta{color:var(--faint);font-size:11.5px;margin-top:3px;font-family:ui-monospace,SFMono-Regular,Menlo,monospace;overflow-wrap:anywhere}"
    s = s + ".ask{color:var(--amber);font-size:10.5px;font-weight:700;margin:13px 0 6px;text-transform:uppercase;letter-spacing:.05em}"
    s = s + ".cmd{background:#05070a;border:1px solid var(--bd);color:#eef2f7;font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:13px;padding:11px 12px;border-radius:10px;white-space:pre-wrap;word-break:break-word;overflow-wrap:anywhere}"
    s = s + ".acts{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-top:11px}.acts button{width:100%}"
    s = s + ".ctl{display:flex;gap:8px;margin-top:10px}.ctl>form{display:flex;gap:8px;min-width:0}.ctl .steer{flex:1;min-width:0}"
    s = s + "button{border:0;border-radius:11px;font-weight:650;font-size:14px;cursor:pointer;min-height:46px;padding:0 16px;transition:filter .12s}button:active{filter:brightness(.9)}"
    s = s + ".ap{background:var(--grn);color:#04240f}.dn{background:var(--red);color:#fff}"
    s = s + ".ghost{background:var(--surf2);color:var(--tx);width:auto;min-height:42px;font-size:13px;font-weight:600}"
    s = s + "input[type=text],input[type=password]{flex:1;min-width:0;background:#05070a;border:1px solid var(--bd);color:var(--tx);border-radius:11px;padding:0 12px;min-height:42px;font-size:14px}input::placeholder{color:var(--faint)}"
    s = s + "details.jr{margin-top:12px}details.jr>summary{color:var(--faint);font-size:11.5px;cursor:pointer;list-style:none}details.jr>summary::-webkit-details-marker{display:none}details.jr>summary:before{content:'\\25B8 ';color:var(--faint)}details.jr[open]>summary:before{content:'\\25BE '}details.jr[open]>summary{margin-bottom:7px}"
    s = s + ".jr .ln{font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:11.5px;color:var(--mut);padding:2px 0;overflow-wrap:anywhere}.jr .k{color:var(--faint);margin-right:7px}"
    s = s + ".empty{text-align:center;color:var(--mut);padding:44px 16px;line-height:1.7}.empty code{background:var(--surf2);padding:2px 7px;border-radius:6px;color:#cbd5e1}"
    s = s + "footer{color:var(--faint);font-size:11px;margin-top:24px;text-align:center;line-height:1.7}"
    s = s + "</style>"
}

// agents_json builds the /api/state payload: agents (parked-first) each with a
// compact recent-journal array. Shared by GET /api/state and the SSR initial render.
func agents_json(db) (out) {
    prows := sqlite_query(db, "SELECT COUNT(*) AS c FROM agents WHERE status='awaiting'")
    parked := parse_int(unq(jget(prows, "[0].c")))
    rows := sqlite_query(db, "SELECT id, host, provider, status, pending, iters, tokens FROM agents ORDER BY (status='awaiting') DESC, last_seen DESC LIMIT 100", []string{})
    parts := []string{}
    i := 0
    for i < 100 {
        id, e := json_get(rows, "[" + str(i) + "].id")
        if e != "" { i = 100 } else {
            jid := unq(id)
            pfx := "[" + str(i) + "]"
            jrows := sqlite_query(db, "SELECT kind, msg FROM events WHERE agent_id = ? ORDER BY id DESC LIMIT 8", []string{jid})
            obj := "{\"id\":" + json(jid) + ",\"host\":" + json(unq(jget(rows, pfx + ".host"))) + ",\"provider\":" + json(unq(jget(rows, pfx + ".provider"))) + ",\"status\":" + json(unq(jget(rows, pfx + ".status"))) + ",\"pending\":" + json(unq(jget(rows, pfx + ".pending"))) + ",\"iters\":" + str(jint(rows, pfx + ".iters")) + ",\"journal\":" + jrows + "}"
            parts = append(parts, obj)
            i = i + 1
        }
    }
    out = "{\"parked\":" + str(parked) + ",\"agents\":[" + join(parts, ",") + "]}"
}

// host_script: the progressive-enhancement client. Instantiates /app.wasm (built from
// the SAME view.src), polls /api/state every 2.5s and re-renders the #agents list via
// the wasm's render_agents (no full-page reload), and intercepts the approve/deny/stop/
// steer form submits into fetch POSTs. Skips a poll while a steer input is focused so it
// never clobbers what you are typing. With JS off, the SSR list + <noscript> refresh work.
func host_script() (s) {
    s = "<script type=module>(async()=>{"
    s = s + "const app=document.getElementById('agents');let mem,inst;const dec=new TextDecoder(),enc=new TextEncoder();"
    s = s + "const cstr=p=>{const b=new Uint8Array(mem.buffer);let e=p;while(b[e])e++;return dec.decode(b.subarray(p,e))};"
    s = s + "const wasi={fd_write:()=>0,fd_seek:()=>0,fd_close:()=>0,fd_fdstat_get:()=>0};"
    s = s + "try{const r=await WebAssembly.instantiateStreaming(fetch('/app.wasm'),{env:{set_html:p=>{app.innerHTML=cstr(p)}},wasi_snapshot_preview1:wasi});inst=r.instance;}catch(e){return}"
    s = s + "mem=inst.exports.memory;inst.exports._initialize&&inst.exports._initialize();"
    s = s + "const send=j=>{const b=enc.encode(j);const p=Number(inst.exports.buf(BigInt(b.length)));new Uint8Array(mem.buffer).set(b,p);inst.exports.load(BigInt(p))};"
    s = s + "const reload=async()=>{try{const r=await fetch('/api/state',{credentials:'same-origin'});if(r.ok)send(await r.text())}catch(e){}};"
    s = s + "setInterval(()=>{const a=document.activeElement;if(a&&app.contains(a)&&a.tagName==='INPUT')return;reload()},2500);"
    s = s + "app.addEventListener('submit',async e=>{e.preventDefault();const f=e.target;const body=new URLSearchParams(new FormData(f));try{await fetch('/api/decide',{method:'POST',body,credentials:'same-origin'})}catch(x){}f.reset&&f.reset();reload()});"
    s = s + "reload();"
    s = s + "})();</script>"
}

func page() (h) {
    db := dbopen()
    body := render_agents(agents_json(db))
    sqlite_close(db)
    h = "<!doctype html><html lang=en><head><meta charset=utf-8>"
    h = h + "<meta name=viewport content=\"width=device-width,initial-scale=1\">"
    h = h + "<title>roam panel</title>" + styles() + "</head><body>"
    h = h + "<header><h1>&#128752; roam panel</h1></header>"
    h = h + "<div class=sub>approve your remote agents from your phone</div>"
    h = h + "<div id=agents>" + body + "</div>"
    h = h + "<footer>one self-hosted binary, built with machin &middot; live &middot; per-command approve/deny is anthropic/openai; debri = session approval + stop</footer>"
    h = h + "<noscript><meta http-equiv=\"refresh\" content=\"8\"></noscript>"
    h = h + host_script()
    h = h + "</body></html>"
}
func conf_page(title, jobid, decision, exp, t, cmd, host) (h) {
    h = "<!doctype html><html lang=en><head><meta charset=utf-8><meta name=viewport content=\"width=device-width,initial-scale=1\"><title>" + esc(title) + "</title>" + styles() + "</head><body>"
    h = h + "<h1>" + esc(title) + "</h1>"
    if jobid == "" {
        h = h + "<div class=ag><div class=sub>This approval link is invalid or has expired. Open the <a href=\"" + panel_url() + "\">panel</a>.</div></div>"
    } else {
        h = h + "<div class=\"ag park\"><div class=row><span class=host>" + esc(host) + "</span><span class=pv>" + esc(jobid) + "</span></div>"
        if cmd != "" { h = h + "<pre>" + esc(cmd) + "</pre>" }
        cl := "ap"
        if decision == "deny" { cl = "dn" }
        h = h + "<form method=post action=/a>"
        h = h + "<input type=hidden name=j value=\"" + esc(jobid) + "\"><input type=hidden name=d value=\"" + esc(decision) + "\"><input type=hidden name=e value=\"" + esc(exp) + "\"><input type=hidden name=t value=\"" + esc(t) + "\">"
        h = h + "<button class=" + cl + ">Confirm " + esc(decision) + "</button></form></div>"
    }
    h = h + "</body></html>"
}
func done_page(decision) (h) {
    h = "<!doctype html><html lang=en><head><meta charset=utf-8><meta name=viewport content=\"width=device-width,initial-scale=1\"><title>done</title>" + styles() + "</head><body>"
    h = h + "<h1>✓ " + esc(decision) + " recorded</h1><div class=ag><div class=sub>The agent will apply it at its next checkpoint. You can close this. <a href=\"" + panel_url() + "\">Open panel</a></div></div></body></html>"
}

// ---------- router ----------
func handle(req) (res) {
    p := req.path
    qi := index(p, "?")
    if qi >= 0 { p = substr(p, 0, qi) }
    if p == "/_health" { return ok_json("{\"ok\":true,\"service\":\"roam-panel\"}") }
    if p == "/v1/report" && req.method == "POST" { return h_report(req) }
    if p == "/v1/decision" { return h_decision(req) }
    if p == "/app.wasm" { return ok_wasm(read_file_bytes("app.wasm")) }
    if p == "/api/state" {
        if panel_authed(req) == 0 { return err_json("403 Forbidden", "sign in") }
        db := dbopen()
        j := agents_json(db)
        sqlite_close(db)
        return ok_json(j)
    }
    if p == "/login" && req.method == "POST" { return h_login(req) }
    if p == "/api/decide" && req.method == "POST" { return h_decide(req) }
    if p == "/a" && req.method == "POST" { return h_onetap_post(req) }
    if p == "/a" { return h_onetap_get(req) }
    if p == "/" {
        if panel_authed(req) == 0 { return response("200 OK", "text/html; charset=utf-8", login_page("")) }
        return ok_html(page())
    }
    res = not_found()
}
func serve_app(port) {
    println("{\"ok\":true,\"service\":\"roam-panel\",\"port\":" + str(port) + ",\"db\":" + json(dbpath()) + "}")
    serve(port, func(req) { return handle(req) })
}
